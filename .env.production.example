# Civibus Production Environment Variables
# Copy to .env and fill in values before running:
#   docker compose --env-file .env -f infra/docker-compose.prod.yml up
# The explicit --env-file is required because the compose file lives in infra/.
# This file is also the canonical payload shape for the deploy workflow secret
# that writes the production `.env` during VM bootstrap.

# ---------- PostgreSQL ----------
POSTGRES_USER=civibus
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=civibus
# POSTGRES_HOST and POSTGRES_PORT are hardcoded in docker-compose.prod.yml
# (db:5432 for container networking). Listed here for reference only.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------- API Auth & Rate Limiting ----------
# Comma-separated list of valid API keys for authenticated access
CIVIBUS_API_KEYS=
# Comma-separated list of admin-level API keys (entity resolution, etc.)
CIVIBUS_ADMIN_API_KEYS=
# Rate limiting: max requests per window per client
CIVIBUS_RATE_LIMIT_REQUESTS=100
CIVIBUS_RATE_LIMIT_WINDOW_SECONDS=60

# ---------- Web / Stack ----------
# Public origin of the deployed site (e.g. https://civibus.example.com)
# This is the single source of truth for the public URL.
# CIVIBUS_ENV=production and CIVIBUS_CORS_ORIGIN=${ORIGIN} are set
# directly in docker-compose.prod.yml, and the web container derives
# PUBLIC_ORIGIN from this value for trusted canonical metadata URLs.
# Do not duplicate those derived settings here.
ORIGIN=https://civibus.example.com
# Required API key the web frontend uses to authenticate with the API backend.
# Must match one of the keys configured in CIVIBUS_API_KEYS above.
CIVIBUS_API_KEY=

# ---------- Campaign Finance Refresh Wrappers ----------
# Required for infra/scripts/refresh_fec_bulk.sh.
# Example values: 2024, 2026
FEC_BULK_CYCLE=
# Optional override for infra/scripts/refresh_fec_bulk.sh.
# Wrapper default when unset:
#   FEC_BULK_DIR=${FEC_BULK_DIR:-/var/lib/civibus/fec/bulk/${FEC_BULK_CYCLE}}
# FEC_BULK_DIR=/var/civibus/fec-bulk/${FEC_BULK_CYCLE}
