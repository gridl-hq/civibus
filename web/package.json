{
  "name": "civibus-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "npm run lint:browser-tests --",
    "lint:browser-tests": "eslint tests/smoke/**/*.spec.ts --config tests/smoke/eslint.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "vitest run src/lib/server/api/config.test.ts src/lib/server/api/client.test.ts",
    "test:smoke": "bash ./tests/smoke/run-playwright.sh"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^25.5.0",
    "cytoscape": "^3.33.1",
    "eslint": "^10.1.0",
    "eslint-plugin-playwright": "^2.10.1",
    "playwright": "^1.59.1",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "layerchart": "2.0.1"
  },
  "overrides": {
    "cookie": "0.7.2"
  }
}
